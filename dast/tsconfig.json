{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "outDir": "./dist",
        "rootDir": ".",
        "declaration": false,
        "sourceMap": false
    },
    "include": [
        "tests/**/*.ts",
        "helpers/**/*.ts",
        "playwright.config.ts"
    ],
    "exclude": [
        "node_modules",
        "results",
        "dist"
    ]
}